<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ErpRagClient.ViewModels"
             xmlns:m="using:ErpRagClient.Models"
             x:Class="ErpRagClient.Views.MainView"
             x:DataType="vm:MainViewModel">

  <UserControl.Styles>

    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Inter,Segoe UI,sans-serif"/>
      <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style Selector="Border.user-bubble">
      <Setter Property="Background"      Value="#2563EB"/>
      <Setter Property="CornerRadius"    Value="16,16,4,16"/>
      <Setter Property="Padding"         Value="14,10"/>
      <Setter Property="MaxWidth"        Value="520"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="Margin"          Value="48,4,0,4"/>
    </Style>
    <Style Selector="Border.user-bubble TextBlock">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.assist-bubble">
      <Setter Property="Background"      Value="#F1F5F9"/>
      <Setter Property="CornerRadius"    Value="16,16,16,4"/>
      <Setter Property="Padding"         Value="14,10"/>
      <Setter Property="MaxWidth"        Value="560"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin"          Value="0,4,48,4"/>
    </Style>
    <Style Selector="Border.assist-bubble TextBlock">
      <Setter Property="Foreground" Value="#1E293B"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.error-bubble">
      <Setter Property="Background"   Value="#FEF2F2"/>
      <Setter Property="BorderBrush"  Value="#FECACA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding"      Value="14,10"/>
      <Setter Property="MaxWidth"     Value="560"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin"       Value="0,4,0,4"/>
    </Style>
    <Style Selector="Border.error-bubble TextBlock">
      <Setter Property="Foreground" Value="#DC2626"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.source-pill">
      <Setter Property="Background"   Value="#E0E7FF"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding"      Value="8,4"/>
      <Setter Property="Margin"       Value="0,0,4,4"/>
    </Style>
    <Style Selector="Border.source-pill TextBlock">
      <Setter Property="Foreground" Value="#3730A3"/>
      <Setter Property="FontSize"   Value="11"/>
    </Style>

    <Style Selector="TextBox.question-input">
      <Setter Property="CornerRadius"  Value="24"/>
      <Setter Property="Padding"       Value="16,12"/>
      <Setter Property="FontSize"      Value="14"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="BorderBrush"   Value="#CBD5E1"/>
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background"   Value="#2563EB"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="Padding"      Value="20,12"/>
      <Setter Property="FontSize"     Value="14"/>
      <Setter Property="FontWeight"   Value="Medium"/>
      <Setter Property="Cursor"       Value="Hand"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#94A3B8"/>
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="Foreground"   Value="#64748B"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding"      Value="10,8"/>
      <Setter Property="FontSize"     Value="12"/>
      <Setter Property="Cursor"       Value="Hand"/>
    </Style>

    <Style Selector="Button.health-tap">
      <Setter Property="Background"   Value="Transparent"/>
      <Setter Property="Foreground"   Value="#64748B"/>
      <Setter Property="Padding"      Value="0"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Background="#FAFBFC"
        MaxWidth="800">

    <Border Grid.Row="0"
            Background="White"
            BoxShadow="0 1 3 0 #1A000000"
            Padding="16,12">
      <Grid RowDefinitions="Auto,Auto,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
            <Border Background="#EFF6FF" CornerRadius="8" Padding="8,6">
              <TextBlock Text="⚙" FontSize="18"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="ERP Assistant"
                         FontSize="17"
                         FontWeight="SemiBold"
                         Foreground="#0F172A"/>
              <TextBlock Text="Powered by your local RAG server"
                         FontSize="11"
                         Foreground="#94A3B8"/>
            </StackPanel>
          </StackPanel>

          <Button Grid.Column="1"
                  Classes="ghost"
                  Command="{Binding ClearChatCommand}"
                  IsVisible="{Binding HasMessages}"
                  ToolTip.Tip="Clear conversation">
            <TextBlock Text="Clear" FontSize="12"/>
          </Button>

          <Button Grid.Column="2"
                  Classes="health-tap"
                  Command="{Binding CheckHealthCommand}"
                  VerticalAlignment="Center"
                  Margin="8,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8" Fill="{Binding HealthColor}"/>
              <TextBlock Text="{Binding HealthText}" FontSize="12" Foreground="#64748B"/>
            </StackPanel>
          </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
          <TextBox Grid.Column="0"
                   Text="{Binding ServerUrl}"
                   Watermark="http://localhost:8000"
                   FontSize="12"
                   Padding="10,6"
                   CornerRadius="8"
                   BorderBrush="#E2E8F0"
                   Margin="0,0,8,0"/>
          <Button Grid.Column="1"
                  Classes="ghost"
                  Command="{Binding CheckHealthCommand}"
                  ToolTip.Tip="Test connection"
                  Padding="10,6">
            <TextBlock Text="Check" FontSize="12"/>
          </Button>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="{Binding HealthInfo}"
                   FontSize="11"
                   Foreground="#64748B"
                   Margin="2,4,0,0"
                   IsVisible="{Binding HealthInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  x:Name="ChatScroll"
                  Padding="16,12">

      <Panel>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    IsVisible="{Binding !HasMessages}"
                    Margin="0,60,0,0">
          <TextBlock Text="💬"
                     FontSize="48"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Ask anything about your ERP system"
                     FontSize="16"
                     FontWeight="Medium"
                     Foreground="#64748B"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Your questions are answered from the ERP documentation&#xa;indexed in your local RAG server."
                     FontSize="13"
                     Foreground="#94A3B8"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="320"/>

          <StackPanel Spacing="8" Margin="0,12,0,0">
            <TextBlock Text="Try asking:"
                       FontSize="12"
                       Foreground="#94A3B8"
                       HorizontalAlignment="Center"/>
            <WrapPanel HorizontalAlignment="Center">
              <Button Classes="ghost"
                      Command="{Binding SendCommand}"
                      Padding="12,7"
                      Margin="0,0,8,0">
                <TextBlock Text="How do I create a purchase order?" FontSize="12"/>
              </Button>
              <Button Classes="ghost"
                      Command="{Binding SendCommand}"
                      Padding="12,7"
                      Margin="0,0,8,0">
                <TextBlock Text="What is the inventory module?" FontSize="12"/>
              </Button>
              <Button Classes="ghost"
                      Command="{Binding SendCommand}"
                      Padding="12,7">
                <TextBlock Text="How to approve an invoice?" FontSize="12"/>
              </Button>
            </WrapPanel>
          </StackPanel>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Messages}"
                      IsVisible="{Binding HasMessages}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="m:ChatMessage">

              <StackPanel Margin="0,0,0,8">

                <StackPanel IsVisible="{Binding IsUser}">
                  <TextBlock Text="{Binding TimeLabel}"
                             FontSize="10"
                             Foreground="#CBD5E1"
                             HorizontalAlignment="Right"
                             Margin="0,0,4,2"/>
                  <Border Classes="user-bubble">
                    <TextBlock Text="{Binding Content}"/>
                  </Border>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsAssistant}">
                  <TextBlock Text="{Binding TimeLabel}"
                             FontSize="10"
                             Foreground="#CBD5E1"
                             Margin="4,0,0,2"/>
                  <Border Classes="assist-bubble">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{Binding Content}"
                                 LineHeight="22"/>

                      <StackPanel IsVisible="{Binding HasSources}" Spacing="4">
                        <TextBlock Text="Sources"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="#94A3B8"/>
                        <ItemsControl ItemsSource="{Binding Sources}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:SourceDoc">
                              <Border Classes="source-pill" Margin="0,0,4,4">
                                <TextBlock Text="{Binding DisplayText}"/>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock FontSize="11" Foreground="#CBD5E1">
                          <Run Text="{Binding ChunksUsed}"/>
                          <Run Text=" document chunks used"/>
                        </TextBlock>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>

                <Border Classes="error-bubble" IsVisible="{Binding IsError}">
                  <StackPanel Spacing="4">
                    <TextBlock Text="⚠ Connection Error"
                               FontWeight="Medium"
                               FontSize="13"/>
                    <TextBlock Text="{Binding Content}" FontSize="12"/>
                  </StackPanel>
                </Border>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Panel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="White"
            BoxShadow="0 -1 3 0 #0D000000"
            Padding="16,12">
      <StackPanel Spacing="8">

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    IsVisible="{Binding IsLoading}"
                    HorizontalAlignment="Center">
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     Foreground="#64748B"/>
          <Button Classes="ghost"
                  Command="{Binding CancelCommand}"
                  Padding="6,2">
            <TextBlock Text="Cancel" FontSize="11" Foreground="#EF4444"/>
          </Button>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="#94A3B8"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding HasStatusMessage}"/>

        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Classes="question-input"
                   Text="{Binding CurrentQuestion}"
                   Watermark="Ask a question about your ERP system…"
                   MaxLines="4"
                   AcceptsReturn="False"
                   IsEnabled="{Binding !IsLoading}"
                   Margin="0,0,10,0">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Return"
                          Command="{Binding SendCommand}"/>
            </TextBox.KeyBindings>
          </TextBox>

          <Button Grid.Column="1"
                  Classes="primary"
                  Command="{Binding SendCommand}"
                  IsEnabled="{Binding CanSend}"
                  Width="60"
                  Height="46">
            <Panel>
              <TextBlock Text="↑"
                         FontSize="20"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !IsLoading}"/>
              <TextBlock Text="…"
                         FontSize="20"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding IsLoading}"/>
            </Panel>
          </Button>

        </Grid>

        <TextBlock Text="Answers are based on your indexed ERP documents only."
                   FontSize="10"
                   Foreground="#CBD5E1"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
